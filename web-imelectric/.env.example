# Google Analytics 4 — ID de medición (ej. G-XXXXXXXXXX)
# https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity — ID del proyecto (cadena del snippet)
# https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Resend — envío de correos desde formularios (API /api/contact)
# https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=
# Remitente verificado en Resend (ej. "IMELECTRIC <notificaciones@tudominio.com>")
RESEND_FROM_EMAIL=
# Destino de los leads/consultas (por defecto contacto@imelectric.es)
CONTACT_TO_EMAIL=
